# Turso Database Configuration (Server-Side Only)
TURSO_URL=your_turso_db_url
TURSO_AUTH_TOKEN=your_turso_auth_token

# Shared Secret (For Server-to-DB internal validation)
APP_API_KEY=your_random_secret_key_here

# Resend Email Configuration
RESEND_API_KEY=re_your_api_key_here

# Note: VITE_APP_API_KEY is no longer used in the frontend for security reasons.
# Authentication is now handled via secure session tokens generated by the API.
